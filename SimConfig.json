{
  // -- World clock ------------------------------------------------------------
  // 1 real second = 120 game seconds = 2 game minutes.
  // The in-game time slider multiplies on top of this.
  "world": {
    "defaultTimeScale": 120.0
  },

  // -- Entities ---------------------------------------------------------------
  "entities": {
    "human": {
      "metabolism": {
        // Starts at 90% (not 100%) so EatUrgency/DrinkUrgency > SleepUrgency at 6 AM
        // — prevents Billy from falling asleep on the very first tick.
        "satiationStart":            90.0,
        "hydrationStart":            90.0,
        "bodyTemp":                  37.0,

        // Hunger in ~5.6 game hours → ~3 meals/day (breakfast ~10AM, lunch ~1PM, dinner ~6PM)
        "satiationDrainRate":         0.002,

        // Thirst in ~2.1 game hours awake → ~7 drinks/day while awake
        "hydrationDrainRate":         0.004,

        // During sleep, metabolism drops to 10% of awake rate.
        // An 8-hour sleep costs only ~11.5% hydration instead of crashing to zero.
        "sleepMetabolismMultiplier":  0.10
      },
      "stomach": {
        // ~100 ml digested per game-hour
        "digestionRate": 0.017
      },
      "energy": {
        "energyStart":         90.0,   // well rested — just woke at 6 AM
        "sleepinessStart":      5.0,   // nearly zero after a proper night's sleep

        // Awake: energy drains ~58 pts over 16 game hours
        "energyDrainRate":     0.001,

        // Awake: sleepiness builds ~69 pts over 16 game hours (5% → ~74% by 10 PM)
        "sleepinessGainRate":  0.0012,

        // Sleep: energy restores to 100% within ~8 game hours
        "energyRestoreRate":   0.003,

        // Sleep: sleepiness drains from ~74% → 5% in ~8.3 game hours (full night's sleep)
        "sleepinessDrainRate": 0.002
      },
      "mood": {
        // Emotionally neutral at start — no initial joy, no initial boredom
        "joyStart":          0.0,
        "trustStart":        0.0,
        "fearStart":         0.0,
        "surpriseStart":     0.0,
        "sadnessStart":      0.0,
        "disgustStart":      0.0,
        "angerStart":        0.0,
        "anticipationStart": 0.0
      },
      "smallIntestine": {
        // 25 ml of chyme clears in ~52 game-minutes — realistic SI transit
        "absorptionRate":         0.008,
        // 40% of processed SI volume becomes LI waste
        "residueToLargeFraction": 0.4
      },
      "largeIntestine": {
        // Slow, persistent water recovery from waste content
        "waterReabsorptionRate": 0.001,
        // ~10.8 ml/game-hour toward the colon
        "mobilityRate":          0.003,
        // 60% of LI content solidifies into stool; remainder dissipates
        "stoolFraction":         0.6
      },
      "colon": {
        // Urge kicks in at 100 ml (50% fill) — entity is aware but not desperate
        "urgeThresholdMl": 100.0,
        // At 200 ml the colon is full; BowelCriticalTag forces Defecate as dominant
        "capacityMl":      200.0
      },
      "bladder": {
        // FillRate 0.010 ml/game-second → urge threshold (70 ml) in ~2 game-hours.
        // At TimeScale 120 this gives ~6–8 urination events per awake game-day.
        "fillRate":        0.010,
        "urgeThresholdMl": 70.0,
        "capacityMl":      100.0
      }
    },

    "cat": {
      "metabolism": {
        "satiationStart":            100.0,
        "hydrationStart":            100.0,
        "bodyTemp":                   38.5,
        "satiationDrainRate":          0.004,
        "hydrationDrainRate":          0.006,
        "sleepMetabolismMultiplier":   0.05  // cats barely lose resources during their many naps
      },
      "stomach": {
        "digestionRate": 0.010
      },
      "energy": {
        "energyStart":         75.0,
        "sleepinessStart":     30.0,
        "energyDrainRate":     0.0006,
        "sleepinessGainRate":  0.0008,
        "energyRestoreRate":   0.003,
        "sleepinessDrainRate": 0.004
      },
      "mood": {
        "joyStart":          0.0,
        "trustStart":        0.0,
        "fearStart":         0.0,
        "surpriseStart":     0.0,
        "sadnessStart":      0.0,
        "disgustStart":      0.0,
        "angerStart":        0.0,
        "anticipationStart": 0.0
      },
      "smallIntestine": {
        "absorptionRate":         0.010,
        "residueToLargeFraction": 0.35
      },
      "largeIntestine": {
        "waterReabsorptionRate": 0.0008,
        "mobilityRate":          0.004,
        "stoolFraction":         0.55
      },
      "colon": {
        "urgeThresholdMl": 80.0,
        "capacityMl":      160.0
      },
      "bladder": {
        // Cats urinate less frequently — roughly every 4–6 game-hours.
        "fillRate":        0.004,
        "urgeThresholdMl": 40.0,
        "capacityMl":      60.0
      }
    }
  },

  // -- Systems ----------------------------------------------------------------
  "systems": {

    "biologicalCondition": {
      // THIRSTY when hydration < 70% (thirst = 30)
      "thirstTagThreshold":     30.0,
      // DEHYDRATED when hydration < 30% (thirst = 70) — severe
      "dehydratedTagThreshold": 70.0,
      // HUNGRY when satiation < 70% (hunger = 30)
      "hungerTagThreshold":     30.0,
      // STARVING when satiation < 20% (hunger = 80) — severe
      "starvingTagThreshold":   80.0,
      // IRRITABLE when either hunger or thirst exceeds 60
      "irritableThreshold":     60.0
    },

    "energy": {
      // Energy (0–100) below which TiredTag is applied
      "tiredThreshold":     60.0,
      // Energy below which ExhaustedTag is applied (supersedes Tired)
      "exhaustedThreshold": 25.0
    },

    "brain": {
      "eatMaxScore":   1.0,
      "drinkMaxScore": 1.0,
      // sleepMaxScore < 1.0 so life-threatening hunger/thirst can always override sleep
      "sleepMaxScore": 0.9,

      // Idle state (Dominant==None) triggers boredom accumulation in MoodSystem.
      // When BoredTag is present, a flat bonus is added to all drives to make even
      // small drives feel more pressing — avoiding permanent idle lock.
      "boredUrgencyBonus": 0.04,

      // If all drive scores remain below this after mood modifiers, zero them
      // all → Dominant = None (the mulling/zoned-out state).
      "minUrgencyThreshold": 0.05,

      // Mood suppression multipliers — applied after base scores
      "sadnessUrgencyMult": 0.80,  // mild suppression (SadTag)
      "griefUrgencyMult":   0.50,  // strong suppression (GriefTag)

      // Defecate drive ceiling. Scaled by ColonComponent.Fill (0–1).
      // At Fill=1.0 with this score = 0.85, defecation beats sleep (0.9 × ~0.75) but
      // yields to critical hunger/thirst. BowelCriticalTag overrides to 1.0 regardless.
      "defecateMaxScore":   0.85,

      // Pee drive ceiling. Scaled by BladderComponent.Fill (0–1).
      // Slightly below defecate (0.85) — a full bladder is uncomfortable but less
      // dangerous than a full colon. BladderCriticalTag overrides to 1.0 regardless.
      "peeMaxScore":        0.80
    },

    "feeding": {
      // FeedingSystem only acts when hunger > this (satiation < 60%)
      "hungerThreshold":   40.0,
      // Stop spawning food once this many kcal are already queued in stomach.
      // v0.7.0+: measured in calories. 240 kcal × 0.3 satiationPerCalorie ≈ 72
      // satiation, matching the pre-v0.7 cap of 70 "nutrition points".
      "nutritionQueueCap": 240.0,
      "banana": {
        "volumeMl":       50.0,
        // Real-world averages for a medium banana (~118 g edible).
        // DigestionSystem converts Calories → Satiation and Water → Hydration
        // using the factors in "digestion" below. Banana: 27g carb + 1.3g prot
        // + 0.4g fat = ~117 kcal × 0.3 = ~35 satiation (matches pre-v0.7 feel).
        "nutrients": {
          "carbohydrates": 27.0,
          "proteins":       1.3,
          "fats":           0.4,
          "fiber":          3.1,
          "water":         89.0,   // ml
          "vitaminB":       0.4,   // mg (mostly B6)
          "vitaminC":      10.0,   // mg
          "potassium":    422.0,   // mg
          "magnesium":     32.0    // mg
        },
        "toughness":       0.2,
        "esophagusSpeed":  0.3
      },

      // Rot parameters for freshly conjured food entities
      // At TimeScale 120: 86400 game-seconds = 1 full game-day of freshness
      "foodFreshnessSeconds": 86400.0,
      // RotLevel per game-second after freshness window expires
      // 0.001 → fully rotten (100%) after ~27.8 additional game-hours
      "foodRotRate": 0.001
    },

    "drinking": {
      // v0.7.0+: caps now measured in ml of water already queued in stomach.
      // 15 ml = one gulp in flight at a time (matches pre-v0.7 feel of cap 30).
      "hydrationQueueCap":           15.0,
      "hydrationQueueCapDehydrated": 30.0,
      "water": {
        "volumeMl":       15.0,
        // Pure water — 15 ml per gulp, nothing else.
        // Via "digestion" factors below: 15ml × 2.0 hydrationPerMl = 30 hydration
        // (matches pre-v0.7 feel of a single gulp restoring ~30% hydration).
        "nutrients": {
          "water": 15.0
        },
        "esophagusSpeed":  0.8
      }
    },

    // -- Digestion --------------------------------------------------------------
    // Converts real-biology nutrients (grams, ml, kcal) into gameplay 0-100
    // metrics. Tuned so the new system matches the pre-v0.7 flat values:
    //   banana 117 kcal × 0.3 = ~35 satiation
    //   water  15 ml  × 2.0 = 30 hydration
    "digestion": {
      "satiationPerCalorie": 0.3,
      "hydrationPerMl":      2.0,
      // 20% of digested stomach volume passes as chyme to the small intestine.
      // The remainder is considered directly absorbed by the stomach.
      "residueFraction":     0.2
    },

    "sleep": {
      // Sleepiness must drop below this before the entity can wake naturally.
      // 15 allows a full 8-game-hour night before waking.
      "wakeThreshold": 15.0
    },

    "interaction": {
      "biteVolumeMl":   50.0,
      "esophagusSpeed":  0.3
    },

    "mood": {
      // -- Tag intensity thresholds (Plutchik three-tier model) ---------------
      // Below lowThreshold  → no tag (emotion is negligible)
      // >= lowThreshold     → low-intensity tag  (serenity, boredom, annoyance…)
      // >= midThreshold     → primary tag         (joy, disgust, anger…)
      // >= highThreshold    → high-intensity tag  (ecstasy, loathing, rage…)
      "lowThreshold":  10.0,
      "midThreshold":  34.0,
      "highThreshold": 67.0,

      // -- Decay rates (per game-second) -------------------------------------
      "positiveDecayRate": 0.005,   // joy, trust, anticipation fade slowly
      "negativeDecayRate": 0.003,   // fear, sadness, disgust, anger linger longer
      "surpriseDecayRate": 0.05,    // surprise is brief — fades fastest

      // -- Gain rates (per game-second unless noted) -------------------------
      // JOY: all needs comfortably met
      "joyGainRate":          0.010,
      "joyComfortThreshold":  60.0,   // satiation/hydration/energy all > 60% required

      // ANGER: irritability unresolved
      "angerGainRate":        0.015,

      // SADNESS: hunger or thirst sustained
      "sadnessGainRate":      0.008,

      // DISGUST (BOREDOM): idle state (Dominant==None)
      "boredGainRate":        0.005,

      // DISGUST SPIKE: consuming rotten food (instant, not per-second)
      "rottenFoodDisgustSpike": 40.0,

      // ANTICIPATION: hunger/thirst building (between min and max thresholds)
      "anticipationGainRate":  0.006,
      "anticipationHungerMin": 15.0,
      "anticipationHungerMax": 50.0
    },

    "rot": {
      // RotLevel (0–100) at which RotTag is applied to a food entity.
      // FeedingSystem checks RotTag; a rotten meal triggers ConsumedRottenFoodTag
      // which MoodSystem converts into a Disgust spike.
      "rotTagThreshold": 30.0
    }

  },

  // -- Movement quality -------------------------------------------------------
  "movement": {
    "stepAsideRadius": 3,
    "stepAsideShift": 0.4,
    "idleJitterTiles": 0.05,
    "idlePostureShiftProb": 0.005,
    "speedModifier": {
      "irritationGainPerPoint": 0.005,
      "affectionLossPerPoint":  0.0033,
      "lowEnergyLossPerPoint":  0.005,
      "minMultiplier":          0.3,
      "maxMultiplier":          2.0
    },
    "pathfinding": {
      "doorwayDiscount":    1.0,
      "tieBreakNoiseScale": 0.1,
      "cacheMaxEntries":    512,
      "cacheEvictionStrategy": "wipeOnChange",
      "logCacheHitRateEveryTick": false,
      "warnIfCacheHitRateBelow": 0.5
    }
  },

  // -- Structural change system -----------------------------------------------
  "structuralChange": {
    "emitOnNpcMovement":     false,
    "emitOnRoomBoundsChange": true
  },

  // -- Spatial engine ---------------------------------------------------------
  "spatial": {
    "cellSizeTiles": 4,
    "worldSize": { "width": 512, "height": 512 },
    "proximityRangeDefaults": {
      "conversationTiles": 2,
      "awarenessTiles":    8,
      "sightTiles":       32
    }
  },

  // -- Lighting engine --------------------------------------------------------
  "lighting": {
    "dayPhaseBoundaries": {
      "earlyMorningStart": 0.20,
      "midMorningStart":   0.30,
      "afternoonStart":    0.45,
      "eveningStart":      0.65,
      "duskStart":         0.80,
      "nightStart":        0.85
    },
    "flickerOnProb":     0.70,
    "dyingDecayProb":    0.05,
    "apertureRangeBase": 5,
    "sourceRangeBase":   3,

    // -- Lighting → drive coupling table -------------------------------------
    // First-match-wins. Conditions are AND of all present clauses.
    // deltasPerTick are floating-point; fractional parts accumulate across ticks.
    // Over 60 ticks (1 sim-minute): irritation 0.08 → ~4 pts, suspicion 0.10 → ~6 pts.
    "driveCouplings": [
      {
        // Flickering fluorescent: small irritation bump + slight loneliness rise.
        // Matches any room type — flickering is unpleasant anywhere.
        "condition": {
          "dominantSourceState": "flickering"
        },
        "deltasPerTick": {
          "irritation": 0.08,
          "loneliness": 0.02
        }
      },
      {
        // Warm desk lamp in a work area: belonging and affection nudge when ambient is adequate.
        "condition": {
          "roomCategoryAny":    ["cubicleGrid", "office"],
          "dominantSourceKind": "deskLamp",
          "ambientLevelMin":    30
        },
        "deltasPerTick": {
          "belonging": 0.05,
          "affection": 0.04
        }
      },
      {
        // Dark hallway after-hours: suspicion rises, mild irritation.
        "condition": {
          "roomCategoryAny": ["hallway", "stairwell"],
          "ambientLevelMax": 20,
          "dayPhaseAny":     ["evening", "dusk", "night"]
        },
        "deltasPerTick": {
          "suspicion":  0.10,
          "irritation": 0.04
        }
      },
      {
        // Sunlight streaming through a window aperture: mood lift and loneliness recovery.
        "condition": {
          "apertureBeamPresent": true
        },
        "deltasPerTick": {
          "loneliness": -0.05,
          "belonging":   0.03
        }
      },
      {
        // Pitch dark (dead fluorescent, basement corner): belonging decay and loneliness rise.
        "condition": {
          "ambientLevelMax": 5
        },
        "deltasPerTick": {
          "belonging":  -0.03,
          "loneliness":  0.06
        }
      },
      {
        // Server-room LED glow: slightly disorienting. Per-archetype tolerance deferred to WP-1.5.B.
        "condition": {
          "roomCategoryAny":    ["itCloset"],
          "dominantSourceKind": "serverLed"
        },
        "deltasPerTick": {
          "irritation": 0.03
        }
      }
    ]
  },

  // -- Narrative telemetry channel -------------------------------------------
  "narrative": {
    // Drive delta (one tick to next) required to emit DriveSpike
    "driveSpikeThreshold":         15,
    // Willpower drop in a single tick required to emit WillpowerCollapse
    "willpowerDropThreshold":      10,
    // Willpower level below which WillpowerLow is emitted (once per descent)
    "willpowerLowThreshold":       20,
    // Ticks after a DriveSpike during which a room departure → LeftRoomAbruptly
    "abruptDepartureWindowTicks":   3,
    // Maximum character length of the Detail field
    "candidateDetailMaxLength":   280
  },

  // -- Cast generator ---------------------------------------------------------
  "castGenerator": {
    "elevatedDriveRange":          [55, 75],
    "depressedDriveRange":         [25, 45],
    "neutralDriveRange":           [40, 60],
    "currentJitterRange":          [-5, 5],
    "rivalryCount":                2,
    "oldFlameCount":               1,
    "mentorPairCount":             1,
    "sleptWithSpouseCount":        1,
    "friendPairCount":             2,
    "thingNobodyTalksAboutCount":  2,
    "relationshipIntensityRange":  [30, 70]
  },

  // -- Persistent chronicle --------------------------------------------------
  "chronicle": {
    // Maximum entries before oldest are dropped.
    "maxEntries": 4096,
    "thresholdRules": {
      // Minimum relationship-intensity delta to persist a relationship-changing candidate.
      "intensityChangeMinForRelationshipStick": 15,
      // Post-spike irritation value required for physical-manifest spawning.
      "irritationSpikeMinForPhysicalManifest": 70,
      // Game-seconds window used when checking drive-return-to-baseline.
      "driveReturnToBaselineWindowSeconds": 60,
      // Minimum distinct NPCs referencing the same event kind to trigger talk-about.
      "talkAboutMinReferenceCount": 2
    },
    // [min, max] magnitude for stain entities.
    "stainMagnitudeRange": [10, 80],
    // [min, max] magnitude for broken-item entities.
    "brokenItemMagnitudeRange": [20, 100]
  },

  // -- Social engine ----------------------------------------------------------
  "social": {
    "driveDecayPerTick": 0.15,
    "driveCircadianAmplitudes": {
      "belonging":  3.0,
      "status":     2.5,
      "affection":  3.0,
      "irritation": 4.0,
      "attraction": 2.0,
      "trust":      1.5,
      "suspicion":  2.0,
      "loneliness": 5.0
    },
    "driveCircadianPhases": {
      "belonging":  0.40,
      "status":     0.30,
      "affection":  0.65,
      "irritation": 0.55,
      "attraction": 0.70,
      "trust":      0.45,
      "suspicion":  0.80,
      "loneliness": 0.85
    },
    "driveVolatilityScale": 1.0,
    "willpowerSleepRegenPerTick": 1,
    "relationshipIntensityDecayPerTick": 0.05
  },

  // -- Dialog system ----------------------------------------------------------
  "dialog": {
    // Fragment use count before calcification eligibility check
    "calcifyThreshold":           8,
    // Fraction of uses in dominant context required to calcify (0.0–1.0)
    "calcifyContextDominanceMin": 0.70,
    // Times listener must hear fragment from same speaker for tic recognition
    "ticRecognitionThreshold":    5,
    // Game-seconds within which a prior use incurs recency penalty
    "recencyWindowSeconds":       300,
    // Score per matching drive valence key
    "valenceMatchScore":          5,
    // Score penalty for recently-used fragment
    "recencyPenalty":             -10,
    // Bonus for calcified fragment
    "calcifyBiasScore":           3,
    // Bonus for fragment previously used with this specific listener
    "perListenerBiasScore":       2,
    // Drive value at or below this maps to "low" ordinal
    "valenceLowMaxValue":         33,
    // Drive value at or below this maps to "mid" ordinal (above: "high")
    "valenceMidMaxValue":         66,
    // Game-days of disuse before decalcification
    "decalcifyTimeoutDays":       30,
    // Relative path to corpus file (searched upward from CWD)
    "corpusPath":                 "docs/c2-content/dialog/corpus-starter.json",
    // Drive level (0–100) at which a drive triggers context selection
    "driveContextThreshold":      60,
    // Per-tick probability an in-range NPC pair attempts dialog
    "dialogAttemptProbability":   0.05
  },

  // -- Stress system ----------------------------------------------------------
  "stress": {
    // AcuteLevel gain per SuppressionTick event (before neuroticism scaling)
    "suppressionStressGain":          1.5,
    // Drive.Current must exceed Drive.Baseline by this much to count as a spike
    "driveSpikeStressDelta":          25,
    // AcuteLevel gain per drive spike per tick
    "driveSpikeStressGain":           2.0,
    // AcuteLevel gain per social conflict event (LeftRoomAbruptly on narrative bus)
    "socialConflictStressGain":       3.0,
    // AcuteLevel lost per tick to natural decay (fractional; accumulated internally)
    "acuteDecayPerTick":              0.05,
    // AcuteLevel thresholds for stress tags
    "stressedTagThreshold":           60,
    "overwhelmedTagThreshold":        85,
    // ChronicLevel threshold for BurningOutTag (sticky for cooldownDays after drop)
    "burningOutTagThreshold":         70,
    "burningOutCooldownDays":         3,
    // Base magnitude of extra SuppressionTick pushed when AcuteLevel >= StressedTagThreshold
    "stressAmplificationMagnitude":   1.0,
    // Fraction of AcuteLevel added to drive volatility multiplier (0.5 = max stress doubles volatility)
    "stressVolatilityScale":          0.5,
    // Per point of Neuroticism: stress gain *= (1 + N * factor); -2..+2 → 0.6..1.4 at 0.2
    "neuroticismStressFactor":        0.2
  },

  // -- Schedule layer ---------------------------------------------------------
  "schedule": {
    // Weight of schedule-driven Approach/Linger candidates vs drive-driven ones.
    "scheduleAnchorBaseWeight":     0.30,
    // Distance (tiles) below which AtDesk/Sleeping emits Linger instead of Approach.
    "scheduleLingerThresholdCells": 2.0
  },

  // -- Memory system ---------------------------------------------------------
  "memory": {
    // Maximum entries per relationship pair before oldest is dropped
    "maxRelationshipMemoryCount": 32,
    // Maximum personal entries per NPC before oldest is dropped
    "maxPersonalMemoryCount": 16
  },

  // -- Workload system -------------------------------------------------------
  "workload": {
    // Game-hour at which TaskGeneratorSystem fires each day (24h clock)
    "taskGenerationHourOfDay":        8.0,
    // Tasks created per generation event
    "taskGenerationCountPerDay":      5,
    // Task effort (game-hours) range
    "taskEffortHoursMin":             0.5,
    "taskEffortHoursMax":             6.0,
    // Deadline offset from now (game-hours) range
    "taskDeadlineHoursMin":           4.0,
    "taskDeadlineHoursMax":           48.0,
    // Task priority range [min, max]
    "taskPriorityMin":                30,
    "taskPriorityMax":                80,
    // Base progress rate (fraction per game-second, before multipliers)
    "baseProgressRatePerSecond":      0.0001,
    // Per Conscientiousness point: rate *= (1 + C * bias)
    "conscientiousnessProgressBias":  0.10,
    // QualityLevel lost per game-second under poor conditions
    "qualityDecayPerStressedTick":    0.0002,
    // QualityLevel recovered per game-second under good conditions
    "qualityRecoveryPerGoodTick":     0.0001,
    // Weight of Work candidate in ActionSelectionSystem
    "workActionBaseWeight":           0.40,
    // Stress gain per overdue task per tick (before neuroticism scaling)
    "overdueTaskStressGain":          1.0
  },

  // -- Social mask system -----------------------------------------------------
  "socialMask": {
    // Maximum mask delta gained per tick at full drive + full exposure
    "maskGainPerTick":              0.5,
    // Mask delta lost per tick when in low-exposure context
    "maskDecayPerTick":              0.3,
    // Exposure factor below which mask decays instead of grows
    "lowExposureThreshold":          0.30,
    // Per point of Conscientiousness: gain *= (1 + C * scale)
    "personalityMaskScale":          0.20,
    // Per point of Extraversion: gain *= (1 - E * scale)
    "personalityExtraversionScale":  0.10,
    // Crack fires when crackPressure >= crackThreshold
    "crackThreshold":                1.50,
    // Fraction of AcuteLevel added to crack pressure
    "stressCrackContribution":       0.50,
    // Flat crack pressure bonus when BurningOutTag is present
    "burnoutCrackBonus":             0.30,
    // Willpower at or below this contributes to crack pressure
    "lowWillpowerThreshold":         30,
    // Minimum ticks between cracks for the same NPC (≈ 30 game-minutes)
    "slipCooldownTicks":             1800
  },

  // -- Physiology gate system ------------------------------------------------
  // PhysiologyGateSystem computes per-NPC veto sets: when an inhibition is strong
  // enough (accounting for willpower leakage and stress relaxation), it blocks the
  // matching physiology action for the tick.
  "physiologyGate": {
    // Effective veto strength at or above which the action is blocked (0–1).
    // 0.50 = a 50% effective inhibition is sufficient to veto.
    "vetoStrengthThreshold":    0.50,
    // Willpower below this triggers leakage that weakens the veto.
    // At willpower == 0, leakage == 1 (gate fully open).
    "lowWillpowerLeakageStart": 30,
    // Fraction by which 100% acute stress relaxes the veto.
    // 0.7 means a maximally stressed NPC has only 30% normal veto strength.
    "stressMaxRelaxation":      0.7
  },

  // -- Life state -------------------------------------------------------------
  // WP-3.0.0: death substrate. Downstream packets (3.0.1+) tune per-cause values.
  "lifeState": {
    // Ticks an Incapacitated NPC has before automatic Deceased transition (~3 game-minutes)
    "defaultIncapacitatedTicks":   180,
    // Whether an Incapacitated NPC's bladder may void (physiologically realistic)
    "incapacitatedAllowsBladderVoid": true,
    // Whether Deceased NPC's PositionComponent is frozen (blocks MovementSystem)
    "deceasedFreezesPosition":     true,
    // Whether InvariantSystem emits a deceased-invariant check on each Deceased transition
    "emitDeathInvariantOnTransition": true
  },

  // -- Choking scenario (WP-3.0.1) -------------------------------------------
  // ChokingDetectionSystem runs at Cleanup phase before LifeStateTransitionSystem.
  // A tough bolus + a distracted NPC (low energy OR high stress OR high irritation)
  // triggers an incapacitation request with the per-cause tick budget below.
  "choking": {
    // BolusComponent.Toughness (0–1) at or above which a bolus is a choking hazard.
    // Banana default is 0.2 — safe. Tough food (jerky ~0.8) is dangerous when distracted.
    "bolusSizeThreshold":        0.65,
    // EnergyComponent.Energy (0–100) strictly below which the NPC is fatigued enough to choke.
    "energyThreshold":           40.0,
    // StressComponent.AcuteLevel (0–100) at or above which motor coordination is impaired.
    "stressThreshold":           70,
    // SocialDrivesComponent.Irritation.Current (0–100) at or above which inattentive eating applies.
    "irritationThreshold":       65,
    // Ticks in Incapacitated before LifeStateTransitionSystem auto-promotes to Deceased.
    // At TimeScale 120, 90 ticks ≈ 1.5 game-minutes (faster than the generic 180-tick default).
    "incapacitationTicks":       90,
    // Acute panic level (0..1) applied to MoodComponent.PanicLevel at choke onset.
    // Decays each tick at MoodSystemConfig.NegativeDecayRate.
    "panicMoodIntensity":        0.85,
    // When true, emits a ChokeStarted narrative candidate so witnesses record the onset.
    "emitChokeStartedNarrative": true
  },

  // -- Bereavement (WP-3.0.2) ------------------------------------------------
  // Two-tier bereavement cascade:
  //   Tier 1 (BereavementSystem)            — fires at death-event time; witnesses + colleagues.
  //   Tier 2 (BereavementByProximitySystem) — fires when an NPC enters a corpse's room.
  "bereavement": {
    // Stress gain applied once to the witness of a death (StressSystem branch, one-shot).
    "witnessedDeathStressGain":           20.0,
    // Stress gain applied once per bereavement event to non-witness colleagues.
    "bereavementStressGain":               5.0,
    // GriefLevel (0–100) applied to witness immediately (Max with current).
    "witnessGriefIntensity":              80.0,
    // GriefLevel ceiling for colleagues before scaling by relationship intensity fraction.
    "colleagueBereavementGriefIntensity": 40.0,
    // Minimum relationship Intensity to trigger colleague bereavement (0–100).
    "bereavementMinIntensity":            20,
    // Minimum relationship Intensity to trigger proximity bereavement (0–100).
    "proximityBereavementMinIntensity":   30,
    // Direct AcuteLevel added (one-shot per NPC/corpse pair) on room entry.
    "proximityBereavementStressGain":      8.0
  },

  // -- Corpse (WP-3.0.2) -----------------------------------------------------
  // Reserved for future per-cause or per-archetype corpse tuning.
  "corpse": {},

  // -- Fainting (WP-3.0.6) ---------------------------------------------------
  // An NPC whose Fear emotion (0–100) exceeds fearThreshold faints:
  // they enter Incapacitated for faintDurationTicks and then automatically
  // recover to Alive. Fainting is never fatal.
  "fainting": {
    // MoodComponent.Fear (0–100) at or above which an Alive NPC faints (~terror level).
    "fearThreshold":                      85.0,

    // Ticks the NPC remains unconscious before automatic recovery.
    // Budget is set to faintDurationTicks+1 so death-by-budget cannot fire first.
    "faintDurationTicks":                 20,

    // Emit a Fainted narrative candidate before the Incapacitated request is enqueued.
    "emitFaintedNarrative":               true,

    // Emit a RegainedConsciousness candidate before the Alive recovery request.
    "emitRegainedConsciousnessNarrative": true
  },

  // -- Action selection -------------------------------------------------------
  "actionSelection": {
    // Drive.Current must exceed this to enumerate candidates
    "driveCandidateThreshold":       60,
    // Idle wins when nothing else exceeds this floor
    "idleScoreFloor":                0.20,
    // stake above this enables approach-avoidance flip
    "inversionStakeThreshold":       0.55,
    // matched inhibition above this (combined with stake) completes the flip
    "inversionInhibitionThreshold":  0.50,
    // how much low-willpower leaks suppressed push through the gate
    "suppressionGiveUpFactor":       0.30,
    // closeness that marks a candidate as actively suppressed
    "suppressionEpsilon":            0.10,
    // willpower cost scaling for suppression events
    "suppressionEventMagnitudeScale": 5,
    // per-point personality nudge (Conscientiousness/Openness)
    "personalityTieBreakWeight":     0.05,
    // hard cap on candidates per NPC per tick
    "maxCandidatesPerTick":          32,
    // tiles the avoidance flee target is pushed away from the threat
    "avoidStandoffDistance":         4
  },

  // -- Life state system ------------------------------------------------------
  "lifeState": {
    // Default number of ticks an NPC stays Incapacitated before transitioning to Deceased.
    // At 60 FPS / 20 game-ticks per second ≈ 9 seconds per game-tick, 180 ticks ≈ 3 game-minutes.
    "defaultIncapacitatedTicks": 180,
    // Whether Incapacitated NPCs can autonomously void their bladder
    "incapacitatedAllowsBladderVoid": true,
    // Whether a Deceased NPC's PositionComponent is frozen (does not change position)
    "deceasedFreezesPosition": true,
    // Whether to emit an invariant check when an NPC transitions to Deceased
    "emitDeathInvariantOnTransition": true
  },
  "choking": {
    // Bolus size threshold (fraction of esophagus capacity, 0..1) above which choking is possible
    "bolusSizeThreshold": 0.65,
    // Energy threshold below which an NPC is considered distracted-tired
    "energyThreshold": 30,
    // Acute stress threshold at or above which an NPC is considered distracted-stressed
    "stressThreshold": 60,
    // Irritation drive threshold at or above which an NPC is considered frustrated-eating
    "irritationThreshold": 70,
    // Number of ticks the choking NPC remains Incapacitated before transition to Deceased
    "incapacitationTicks": 180,
    // Mood panic intensity set on choke (0..1 scale)
    "panicMoodIntensity": 0.85,
    // Dev kill-switch for choke-started narrative emission
    "emitChokeStartedNarrative": true
  },
  "slipAndFall": {
    // Global multiplier on slip chance. Scales the product of (risk * speed * stress).
    // Default 0.001 (very low baseline; high-risk stains at high speed are rare death).
    "globalSlipChanceScale": 0.001,
    // Acute stress level above which StressSlipMultiplier applies
    "stressDangerThreshold": 60,
    // Multiplier on slip chance when NPC's AcuteStress >= StressDangerThreshold
    "stressSlipMultiplier": 2.0,
    // Default fall risk level for broken items
    "fallRiskBrokenItemDefault": 0.50,
    // Default fall risk level for water stains
    "fallRiskWaterDefault": 0.40,
    // Default fall risk level for blood stains
    "fallRiskBloodDefault": 0.60,
    // Default fall risk level for oil stains
    "fallRiskOilDefault": 0.85
  },
  "lockout": {
    // Hour of the game-day (0..24) at which LockoutDetectionSystem runs
    "lockoutCheckHour": 18.0,
    // Hunger threshold (Satiation <= 100 - this value triggers lockout detection)
    "lockoutHungerThreshold": 95,
    // Game-days an NPC can survive locked in before starvation death
    "starvationTicks": 5,
    // Named anchor tag used to identify outdoor exits
    "exitNamedAnchorTag": "outdoor"
  }
}
