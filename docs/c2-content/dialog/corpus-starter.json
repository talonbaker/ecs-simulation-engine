    { "id": "academic-agreement-1", "text": "That's actually a fairly astute observation.", "register": "academic", "context": "agreement", "valenceProfile": { "affection": "low", "status": "mid" }, "noteworthiness": 25 },
    { "id": "academic-agreement-2", "text": "I was thinking something quite similar.", "register": "academic", "context": "agreement", "valenceProfile": { "belonging": "mid" }, "noteworthiness": 22 },
    { "id": "academic-complaint-1", "text": "What I'd observe is that this system has deep structural issues.", "register": "academic", "context": "complaint", "valenceProfile": { "irritation": "high", "status": "mid" }, "noteworthiness": 52 },
    { "id": "academic-complaint-2", "text": "It's more nuanced than a simple complaint, but this isn't working.", "register": "academic", "context": "complaint", "valenceProfile": { "irritation": "mid" }, "noteworthiness": 45 },
    { "id": "academic-complaint-3", "text": "There's a pattern here I think we keep ignoring.", "register": "academic", "context": "complaint", "valenceProfile": { "irritation": "mid", "suspicion": "mid" }, "noteworthiness": 48 },
    { "id": "academic-flirt-1", "text": "I find myself genuinely looking forward to these conversations.", "register": "academic", "context": "flirt", "valenceProfile": { "affection": "high", "attraction": "high" }, "relationshipFit": ["colleague", "romantic"], "noteworthiness": 65 },
    { "id": "academic-flirt-2", "text": "There's something genuinely interesting about you.", "register": "academic", "context": "flirt", "valenceProfile": { "attraction": "high", "affection": "mid" }, "relationshipFit": ["colleague", "romantic"], "noteworthiness": 62 },
    { "id": "academic-flirt-3", "text": "I've been thinking about what you said, actually.", "register": "academic", "context": "flirt", "valenceProfile": { "attraction": "mid", "affection": "high" }, "relationshipFit": ["closeFriend", "romantic"], "noteworthiness": 58 },
    { "id": "academic-deflect-1", "text": "That's somewhat outside my current area of focus.", "register": "academic", "context": "deflect", "valenceProfile": { "suspicion": "mid" }, "noteworthiness": 30 },
    { "id": "academic-deflect-2", "text": "I'm not positioned to answer that well.", "register": "academic", "context": "deflect", "valenceProfile": { "suspicion": "mid" }, "noteworthiness": 28 },
    { "id": "academic-lashOut-1", "text": "I have to say, I find that genuinely baffling.", "register": "academic", "context": "lashOut", "valenceProfile": { "irritation": "high" }, "noteworthiness": 68 },
    { "id": "academic-lashOut-2", "text": "No, I need to push back on that strongly.", "register": "academic", "context": "lashOut", "valenceProfile": { "irritation": "high", "status": "mid" }, "noteworthiness": 72 },
    { "id": "academic-lashOut-3", "text": "That is genuinely not okay, and I want to be clear about that.", "register": "academic", "context": "lashOut", "valenceProfile": { "irritation": "high" }, "noteworthiness": 75 },
    { "id": "academic-share-1", "text": "I've been doing quite a bit of reflection on this.", "register": "academic", "context": "share", "valenceProfile": { "loneliness": "high", "affection": "mid" }, "relationshipFit": ["closeFriend", "colleague"], "noteworthiness": 68 },
    { "id": "academic-share-2", "text": "I read something recently that reframed my whole situation.", "register": "academic", "context": "share", "valenceProfile": { "loneliness": "mid", "belonging": "low" }, "noteworthiness": 60 },
    { "id": "academic-share-3", "text": "I don't normally say this kind of thing, but.", "register": "academic", "context": "share", "valenceProfile": { "loneliness": "high", "trust": "high" }, "relationshipFit": ["closeFriend"], "noteworthiness": 70 },
    { "id": "academic-brushOff-1", "text": "Let me get back to you on that.", "register": "academic", "context": "brushOff", "valenceProfile": { "irritation": "low" }, "noteworthiness": 15 },
    { "id": "academic-brushOff-2", "text": "That's worth thinking about.", "register": "academic", "context": "brushOff", "valenceProfile": { "irritation": "low" }, "noteworthiness": 12 },
    { "id": "academic-encouragement-1", "text": "I think your approach was actually quite sophisticated.", "register": "academic", "context": "encouragement", "valenceProfile": { "affection": "mid", "status": "mid" }, "noteworthiness": 40 },
    { "id": "academic-encouragement-2", "text": "I don't think people appreciate how good you are at this.", "register": "academic", "context": "encouragement", "valenceProfile": { "affection": "high" }, "noteworthiness": 48 },
    { "id": "academic-thanks-1", "text": "I genuinely appreciate that.", "register": "academic", "context": "thanks", "valenceProfile": { "affection": "mid" }, "noteworthiness": 28 },
    { "id": "academic-thanks-2", "text": "That was actually very helpful.", "register": "academic", "context": "thanks", "valenceProfile": { "affection": "low" }, "noteworthiness": 22 },
    { "id": "academic-apology-1", "text": "I want to acknowledge that I handled that poorly.", "register": "academic", "context": "apology", "valenceProfile": { "trust": "high", "irritation": "low" }, "noteworthiness": 50 },
    { "id": "academic-apology-2", "text": "I owe you an apology — that wasn't fair.", "register": "academic", "context": "apology", "valenceProfile": { "affection": "mid", "trust": "high" }, "noteworthiness": 52 },
    { "id": "academic-acknowledge-1", "text": "Interesting.", "register": "academic", "context": "acknowledge", "valenceProfile": {}, "noteworthiness": 8 },
    { "id": "academic-acknowledge-2", "text": "Hm.", "register": "academic", "context": "acknowledge", "valenceProfile": {}, "noteworthiness": 5 },

    { "id": "folksy-greeting-1", "text": "Well, look who it is.", "register": "folksy", "context": "greeting", "valenceProfile": { "belonging": "mid" }, "noteworthiness": 15 },
    { "id": "folksy-greeting-2", "text": "Haven't seen you in a minute.", "register": "folksy", "context": "greeting", "valenceProfile": { "belonging": "mid" }, "noteworthiness": 12 },
    { "id": "folksy-refusal-1", "text": "I appreciate you asking, but I'm gonna sit this one out.", "register": "folksy", "context": "refusal", "valenceProfile": { "trust": "mid" }, "noteworthiness": 30 },
    { "id": "folksy-refusal-2", "text": "Bless your heart, but no.", "register": "folksy", "context": "refusal", "valenceProfile": { "irritation": "low" }, "noteworthiness": 38 },
    { "id": "folksy-agreement-1", "text": "Now you're talking.", "register": "folksy", "context": "agreement", "valenceProfile": { "belonging": "high" }, "noteworthiness": 28 },
    { "id": "folksy-agreement-2", "text": "See, that's what I've been saying.", "register": "folksy", "context": "agreement", "valenceProfile": { "belonging": "mid" }, "noteworthiness": 25 },
    { "id": "folksy-complaint-1", "text": "Boy, I tell ya.", "register": "folksy", "context": "complaint", "valenceProfile": { "irritation": "high", "loneliness": "mid" }, "noteworthiness": 48 },
    { "id": "folksy-complaint-2", "text": "I don't know how much more of this I got in me.", "register": "folksy", "context": "complaint", "valenceProfile": { "irritation": "high", "loneliness": "high" }, "noteworthiness": 62 },
    { "id": "folksy-complaint-3", "text": "This is about the third time this week.", "register": "folksy", "context": "complaint", "valenceProfile": { "irritation": "high" }, "noteworthiness": 52 },
    { "id": "folksy-flirt-1", "text": "You are too much.", "register": "folksy", "context": "flirt", "valenceProfile": { "attraction": "high", "affection": "high" }, "relationshipFit": ["closeFriend", "romantic"], "noteworthiness": 65 },
    { "id": "folksy-flirt-2", "text": "I don't know what I'd do without you around here.", "register": "folksy", "context": "flirt", "valenceProfile": { "attraction": "mid", "loneliness": "low", "affection": "high" }, "relationshipFit": ["closeFriend", "romantic"], "noteworthiness": 70 },
    { "id": "folksy-flirt-3", "text": "You've got something about you.", "register": "folksy", "context": "flirt", "valenceProfile": { "attraction": "high", "affection": "mid" }, "noteworthiness": 60 },
    { "id": "folksy-deflect-1", "text": "That's above my pay grade.", "register": "folksy", "context": "deflect", "valenceProfile": { "suspicion": "low" }, "noteworthiness": 28 },
    { "id": "folksy-deflect-2", "text": "I'm just a simple person.", "register": "folksy", "context": "deflect", "valenceProfile": { "suspicion": "low", "loneliness": "mid" }, "noteworthiness": 30 },
    { "id": "folksy-lashOut-1", "text": "Now you've gone and done it.", "register": "folksy", "context": "lashOut", "valenceProfile": { "irritation": "high" }, "noteworthiness": 70 },
    { "id": "folksy-lashOut-2", "text": "I have had just about enough.", "register": "folksy", "context": "lashOut", "valenceProfile": { "irritation": "high", "loneliness": "mid" }, "noteworthiness": 72 },
    { "id": "folksy-lashOut-3", "text": "Lord help me.", "register": "folksy", "context": "lashOut", "valenceProfile": { "irritation": "high" }, "noteworthiness": 68 },
    { "id": "folksy-share-1", "text": "Y'know what my granddad used to say.", "register": "folksy", "context": "share", "valenceProfile": { "loneliness": "high", "affection": "mid" }, "noteworthiness": 70 },
    { "id": "folksy-share-2", "text": "Reminds me of when I was coming up.", "register": "folksy", "context": "share", "valenceProfile": { "loneliness": "mid", "affection": "mid" }, "noteworthiness": 60 },
    { "id": "folksy-share-3", "text": "I probably shouldn't be telling you this, but I trust you.", "register": "folksy", "context": "share", "valenceProfile": { "loneliness": "high", "trust": "high" }, "relationshipFit": ["closeFriend", "colleague"], "noteworthiness": 75 },
    { "id": "folksy-brushOff-1", "text": "Well, bless your heart.", "register": "folksy", "context": "brushOff", "valenceProfile": { "irritation": "low" }, "noteworthiness": 18 },
    { "id": "folksy-brushOff-2", "text": "Mm, we'll see.", "register": "folksy", "context": "brushOff", "valenceProfile": { "irritation": "low" }, "noteworthiness": 12 },
    { "id": "folksy-encouragement-1", "text": "You've got more in you than you know.", "register": "folksy", "context": "encouragement", "valenceProfile": { "affection": "high", "belonging": "mid" }, "noteworthiness": 52 },
    { "id": "folksy-encouragement-2", "text": "Don't you give up now.", "register": "folksy", "context": "encouragement", "valenceProfile": { "affection": "high", "belonging": "high" }, "noteworthiness": 55 },
    { "id": "folksy-thanks-1", "text": "I can't thank you enough.", "register": "folksy", "context": "thanks", "valenceProfile": { "affection": "high", "trust": "mid" }, "noteworthiness": 42 },
    { "id": "folksy-thanks-2", "text": "You're good people.", "register": "folksy", "context": "thanks", "valenceProfile": { "affection": "high", "belonging": "high" }, "noteworthiness": 48 },
    { "id": "folksy-apology-1", "text": "I sure am sorry about that.", "register": "folksy", "context": "apology", "valenceProfile": { "irritation": "low", "trust": "high" }, "noteworthiness": 50 },
    { "id": "folksy-apology-2", "text": "That wasn't right of me.", "register": "folksy", "context": "apology", "valenceProfile": { "trust": "high", "irritation": "low" }, "noteworthiness": 48 },
    { "id": "folksy-acknowledge-1", "text": "Mm-hm.", "register": "folksy", "context": "acknowledge", "valenceProfile": {}, "noteworthiness": 5 },
