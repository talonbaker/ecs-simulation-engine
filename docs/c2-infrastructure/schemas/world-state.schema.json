{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ecs-sim-engine.local/schemas/world-state.schema.json",
  "title": "WorldStateDto",
  "description": "Versioned, AI-consumable projection of SimulationSnapshot. Produced by Warden.Telemetry, consumed by Tier-3 Haikus.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "capturedAt", "tick", "clock", "entities", "worldItems", "worldObjects", "invariants"],
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["0.1.0", "0.2.0"] },
    "capturedAt":    { "type": "string", "format": "date-time" },
    "tick":          { "type": "integer", "minimum": 0 },
    "seed":          { "type": "integer", "minimum": 0, "description": "The RNG seed the sim was booted with. Required for determinism." },
    "simVersion":    { "type": "string", "description": "SimVersion.Full at capture time." },

    "clock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gameTimeDisplay", "dayNumber", "isDaytime", "circadianFactor", "timeScale"],
      "properties": {
        "gameTimeDisplay":  { "type": "string", "maxLength": 32 },
        "dayNumber":        { "type": "integer", "minimum": 0 },
        "isDaytime":        { "type": "boolean" },
        "circadianFactor":  { "type": "number", "minimum": 0, "maximum": 1 },
        "timeScale":        { "type": "number", "minimum": 0, "maximum": 10000 }
      }
    },

    "entities": {
      "type": "array",
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/entityState" }
    },

    "worldItems": {
      "type": "array",
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/worldItem" }
    },

    "worldObjects": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "#/$defs/worldObject" }
    },

    "transitItems": {
      "type": "array",
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/transitItem" }
    },

    "relationships": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/$defs/relationship" }
    },

    "memoryEvents": {
      "type": "array",
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/memoryEvent" }
    },

    "invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": ["violationCount"],
      "properties": {
        "violationCount": { "type": "integer", "minimum": 0 },
        "recentViolations": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tick", "kind", "message"],
            "properties": {
              "tick":    { "type": "integer", "minimum": 0 },
              "kind":    { "type": "string", "maxLength": 64 },
              "message": { "type": "string", "maxLength": 512 }
            }
          }
        }
      }
    }
  },

  "$defs": {
    "entityState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "shortId", "name", "species", "position", "drives", "physiology"],
      "properties": {
        "id":      { "type": "string", "format": "uuid" },
        "shortId": { "type": "string", "minLength": 1, "maxLength": 16 },
        "name":    { "type": "string", "maxLength": 64 },
        "species": { "type": "string", "enum": ["human", "cat", "unknown"] },

        "position": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "z", "hasPosition"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" },
            "hasPosition": { "type": "boolean" },
            "isMoving":    { "type": "boolean" },
            "moveTarget":  { "type": "string", "maxLength": 32 }
          }
        },

        "drives": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dominant", "eatUrgency", "drinkUrgency", "sleepUrgency", "defecateUrgency", "peeUrgency"],
          "properties": {
            "dominant":        { "type": "string", "enum": ["None", "Eat", "Drink", "Sleep", "Defecate", "Pee"] },
            "eatUrgency":      { "type": "number", "minimum": 0, "maximum": 1 },
            "drinkUrgency":    { "type": "number", "minimum": 0, "maximum": 1 },
            "sleepUrgency":    { "type": "number", "minimum": 0, "maximum": 1 },
            "defecateUrgency": { "type": "number", "minimum": 0, "maximum": 1 },
            "peeUrgency":      { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },

        "physiology": {
          "type": "object",
          "additionalProperties": false,
          "required": ["satiation", "hydration", "bodyTemp", "energy", "sleepiness", "isSleeping"],
          "properties": {
            "satiation":   { "type": "number", "minimum": 0, "maximum": 100 },
            "hydration":   { "type": "number", "minimum": 0, "maximum": 100 },
            "bodyTemp":    { "type": "number", "minimum": 20, "maximum": 45 },
            "energy":      { "type": "number", "minimum": 0, "maximum": 100 },
            "sleepiness":  { "type": "number", "minimum": 0, "maximum": 100 },
            "isSleeping":  { "type": "boolean" },
            "siFill":      { "type": "number", "minimum": 0, "maximum": 1 },
            "liFill":      { "type": "number", "minimum": 0, "maximum": 1 },
            "colonFill":   { "type": "number", "minimum": 0, "maximum": 1 },
            "bladderFill": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },

        "social": { "$ref": "#/$defs/socialState" }
      }
    },

    "socialState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selfDrives":         { "$ref": "#/$defs/selfDrives" },
        "personalityTraits": {
          "type": "array",
          "maxItems": 5,
          "items": { "$ref": "#/$defs/personalityTrait" }
        },
        "currentMood":        { "type": "string", "maxLength": 32 },
        "vocabularyRegister": {
          "type": "string",
          "enum": ["formal", "casual", "crass", "clipped", "academic", "folksy"]
        }
      }
    },

    "selfDrives": {
      "type": "object",
      "additionalProperties": false,
      "required": ["belonging", "status", "affection", "irritation", "loneliness"],
      "properties": {
        "belonging":  { "type": "integer", "minimum": 0, "maximum": 100 },
        "status":     { "type": "integer", "minimum": 0, "maximum": 100 },
        "affection":  { "type": "integer", "minimum": 0, "maximum": 100 },
        "irritation": { "type": "integer", "minimum": 0, "maximum": 100 },
        "loneliness": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },

    "personalityTrait": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "value"],
      "properties": {
        "dimension": {
          "type": "string",
          "enum": ["openness", "conscientiousness", "extraversion", "agreeableness", "neuroticism"]
        },
        "value": { "type": "integer", "minimum": -2, "maximum": 2 }
      }
    },

    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "participantA", "participantB", "patterns", "pairDrives", "intensity", "historyEventIds"],
      "properties": {
        "id":           { "type": "string", "format": "uuid" },
        "participantA": { "type": "string", "format": "uuid" },
        "participantB": { "type": "string", "format": "uuid" },
        "patterns": {
          "type": "array",
          "maxItems": 2,
          "items": {
            "type": "string",
            "enum": [
              "rival", "oldFlame", "activeAffair", "secretCrush",
              "mentor", "mentee", "bossOf", "reportTo", "friend",
              "alliesOfConvenience", "sleptWithSpouse", "confidant",
              "theThingNobodyTalksAbout"
            ]
          }
        },
        "pairDrives":      { "$ref": "#/$defs/pairDrives" },
        "intensity":       { "type": "integer", "minimum": 0, "maximum": 100 },
        "historyEventIds": {
          "type": "array",
          "maxItems": 1000,
          "items": { "type": "string", "format": "uuid" }
        }
      }
    },

    "pairDrives": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attraction", "trust", "suspicion", "jealousy"],
      "properties": {
        "attraction": { "type": "integer", "minimum": 0, "maximum": 100 },
        "trust":      { "type": "integer", "minimum": 0, "maximum": 100 },
        "suspicion":  { "type": "integer", "minimum": 0, "maximum": 100 },
        "jealousy":   { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },

    "memoryEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "tick", "participants", "kind", "scope", "description", "persistent"],
      "properties": {
        "id":   { "type": "string", "format": "uuid" },
        "tick": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "participants": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": { "type": "string", "format": "uuid" }
        },
        "kind":           { "type": "string", "maxLength": 64 },
        "scope":          { "type": "string", "enum": ["pair", "global"] },
        "description":    { "type": "string", "maxLength": 280 },
        "persistent":     { "type": "boolean" },
        "relationshipId": { "type": "string", "format": "uuid" }
      }
    },

    "worldItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id":       { "type": "string", "format": "uuid" },
        "label":    { "type": "string", "maxLength": 32 },
        "rotLevel": { "type": "number", "minimum": 0, "maximum": 100 },
        "isRotten": { "type": "boolean" }
      }
    },

    "worldObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind", "x", "y", "z"],
      "properties": {
        "id":         { "type": "string", "format": "uuid" },
        "name":       { "type": "string", "maxLength": 32 },
        "kind":       { "type": "string", "enum": ["fridge", "sink", "toilet", "bed", "other"] },
        "x":          { "type": "number" },
        "y":          { "type": "number" },
        "z":          { "type": "number" },
        "stockCount": { "type": "integer", "minimum": -1 }
      }
    },

    "transitItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "targetEntityId", "contentLabel", "progress"],
      "properties": {
        "id":             { "type": "string", "format": "uuid" },
        "targetEntityId": { "type": "string", "format": "uuid" },
        "contentLabel":   { "type": "string", "maxLength": 32 },
        "progress":       { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
