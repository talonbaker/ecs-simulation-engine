{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ecs-sim-engine.local/schemas/opus-to-sonnet.schema.json",
  "title": "OpusSpecPacket",
  "description": "Single engineering objective handed from Tier-1 (Opus) to Tier-2 (Sonnet). A mission produces 1..5 of these. Each is independently actionable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "specId", "missionId", "title", "rationale",
    "inputs", "deliverables", "acceptanceTests", "nonGoals", "timeboxMinutes", "workerBudgetUsd"
  ],
  "properties": {
    "schemaVersion":    { "type": "string", "const": "0.1.0" },
    "specId":           { "type": "string", "pattern": "^spec-[a-z0-9-]{1,48}$" },
    "missionId":        { "type": "string", "pattern": "^mission-[a-z0-9-]{1,48}$" },
    "title":            { "type": "string", "minLength": 1, "maxLength": 120 },
    "rationale":        { "type": "string", "minLength": 1, "maxLength": 2000, "description": "Why this spec exists. Links the packet to the mission." },

    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["referenceFiles"],
      "properties": {
        "referenceFiles": {
          "type": "array",
          "maxItems": 32,
          "items": { "type": "string", "maxLength": 256, "description": "Repo-relative path. Sonnet must read exactly these." }
        },
        "preconditions": {
          "type": "array",
          "maxItems": 16,
          "items": { "type": "string", "maxLength": 256 }
        },
        "constants": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] },
          "description": "Named scalar inputs the Sonnet should treat as given, not derived."
        }
      }
    },

    "deliverables": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "description"],
        "properties": {
          "kind":        { "type": "string", "enum": ["code", "test", "doc", "schema", "config"] },
          "path":        { "type": "string", "maxLength": 256 },
          "description": { "type": "string", "maxLength": 512 }
        }
      }
    },

    "acceptanceTests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "description": "Binary-checkable assertions. Sonnet's Result.outcome='ok' requires every one to be true.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "assertion", "verification"],
        "properties": {
          "id":           { "type": "string", "pattern": "^AT-[0-9]{2,3}$" },
          "assertion":    { "type": "string", "maxLength": 512 },
          "verification": { "type": "string", "enum": ["unit-test", "build", "manual-review", "schema-validation", "cli-exit-code"] },
          "notes":        { "type": "string", "maxLength": 512 }
        }
      }
    },

    "nonGoals": {
      "type": "array",
      "maxItems": 16,
      "items": { "type": "string", "maxLength": 256 },
      "description": "Things the Sonnet is explicitly forbidden from doing. Prevents scope creep, saves tokens."
    },

    "needsHaikuValidation": {
      "type": "boolean",
      "default": false,
      "description": "If true, Sonnet's Result must include a ScenarioBatch. If false, the mission is code-only."
    },

    "timeboxMinutes":  { "type": "integer", "minimum": 1, "maximum": 120, "description": "Orchestrator kills the job past this wall-clock limit." },
    "workerBudgetUsd": { "type": "number", "minimum": 0.01, "maximum": 5.00, "description": "Orchestrator halts dispatch for this worker if its slice of the ledger exceeds this." }
  }
}
