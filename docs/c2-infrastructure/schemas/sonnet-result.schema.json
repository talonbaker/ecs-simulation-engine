{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ecs-sim-engine.local/schemas/sonnet-result.schema.json",
  "title": "SonnetResult",
  "description": "What a Tier-2 Sonnet returns when it finishes one SpecPacket. Parsed and validated by the orchestrator before any downstream dispatch.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "specId", "workerId", "outcome", "acceptanceTestResults", "tokensUsed"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.1.0" },
    "specId":        { "type": "string", "pattern": "^spec-[a-z0-9-]{1,48}$" },
    "workerId":      { "type": "string", "pattern": "^sonnet-[0-9]{2}$" },

    "outcome": {
      "type": "string",
      "enum": ["ok", "blocked", "failed"],
      "description": "ok = all ATs passed. failed = one or more ATs explicitly false. blocked = could not evaluate; fail-closed."
    },

    "blockReason": {
      "type": "string",
      "enum": [
        "ambiguous-spec",
        "build-failed",
        "tool-error",
        "exception",
        "schema-mismatch-on-own-output",
        "missing-reference-file",
        "budget-exceeded",
        "timebox-exceeded"
      ],
      "description": "Required iff outcome='blocked'."
    },

    "blockDetails": {
      "type": "string",
      "maxLength": 4000,
      "description": "Free-form context. Stack traces, compiler errors, ambiguous requirements. Capped so a runaway worker can't write a novel."
    },

    "worktreePath": {
      "type": "string",
      "maxLength": 512,
      "description": "Filesystem path to the isolated git worktree containing the Sonnet's diff."
    },

    "diffSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filesAdded":    { "type": "integer", "minimum": 0 },
        "filesModified": { "type": "integer", "minimum": 0 },
        "filesDeleted":  { "type": "integer", "minimum": 0 },
        "linesAdded":    { "type": "integer", "minimum": 0 },
        "linesRemoved":  { "type": "integer", "minimum": 0 }
      }
    },

    "acceptanceTestResults": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "passed"],
        "properties": {
          "id":       { "type": "string", "pattern": "^AT-[0-9]{2,3}$" },
          "passed":   { "type": "boolean" },
          "evidence": { "type": "string", "maxLength": 1024, "description": "Link to test output, build log line, or the one-sentence manual verdict." }
        }
      }
    },

    "scenarioBatch": {
      "description": "Present only when the SpecPacket set needsHaikuValidation=true. Becomes the Haiku dispatch payload.",
      "$ref": "./sonnet-to-haiku.schema.json"
    },

    "tokensUsed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "cachedRead", "output"],
      "properties": {
        "input":       { "type": "integer", "minimum": 0 },
        "cachedRead":  { "type": "integer", "minimum": 0 },
        "cacheWrite":  { "type": "integer", "minimum": 0 },
        "output":      { "type": "integer", "minimum": 0 }
      }
    },

    "notes": { "type": "string", "maxLength": 2000, "description": "Optional free-form note to the orchestrator. No commitments, no claims — just context." }
  },

  "allOf": [
    {
      "if":   { "properties": { "outcome": { "const": "blocked" } }, "required": ["outcome"] },
      "then": { "required": ["blockReason"] }
    }
  ]
}
