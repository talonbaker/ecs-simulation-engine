Library/
Temp/
obj/
Build/
Builds/
Logs/
UserSettings/

# Unity-generated project files (canonical source lives in ProjectSettings/ and Packages/)
*.csproj
*.sln

# Visual Studio
*.vcxproj
*.suo
*.user
.vs/

# JetBrains Rider
.idea/

# VS Code
.vscode/

# macOS
.DS_Store

# Compiled DLLs in Plugins/ — generated by build-unity-dll-ecsunity.bat
# Check in Plugins/PLACE_DLLS_HERE.txt instead.
Assets/Plugins/*.dll
Assets/Plugins/*.pdb
