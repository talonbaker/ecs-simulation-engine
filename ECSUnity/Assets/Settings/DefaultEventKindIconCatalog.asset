%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 00000000000000000000000000000000, type: 3}
  m_Name: DefaultEventKindIconCatalog
  m_EditorClassIdentifier:
  # Each entry maps one ChronicleEventKind integer value to a sprite Icon
  # and a TintColor used to tint the kind badge in the event log row.
  #
  # Icon references are intentionally left as {fileID: 0} (null) in this
  # default asset. The EventLogRow binder falls back to a plain coloured
  # square when Icon is null — this keeps the log functional while sprite
  # art is being produced. Replace {fileID: 0} with real sprite file/GUID
  # pairs once art assets are imported.
  #
  # TintColor values use sRGB float components (r/g/b/a each 0.0 - 1.0).
  # Colours are chosen to convey emotional tone at a glance:
  #   Blue-grey  (0.478, 0.702, 0.831) — neutral / minor incidents
  #   Orange     (0.878, 0.502, 0.188) — friction / conflict
  #   Red        (0.816, 0.251, 0.125) — severe / humiliation / firing
  #   Pink       (0.816, 0.439, 0.627) — scandal / affair
  #   Green      (0.235, 0.702, 0.443) — positive / kindness / promotion
  #   Gold       (0.753, 0.627, 0.125) — betrayal (warm warning)
  #   Mid-grey   (0.667, 0.667, 0.667) — death / leaving (muted)
  #   Blue-grey  (0.533, 0.533, 0.667) — uncategorised / other
  _entries:
  # Kind 0: SpilledSomething — minor social friction, blue-grey neutral
  - Kind: 0
    Icon: {fileID: 0}
    TintColor: {r: 0.478, g: 0.702, b: 0.831, a: 1}
  # Kind 1: BrokenItem — minor incident, blue-grey neutral
  - Kind: 1
    Icon: {fileID: 0}
    TintColor: {r: 0.478, g: 0.702, b: 0.831, a: 1}
  # Kind 2: PublicArgument — interpersonal conflict, orange
  - Kind: 2
    Icon: {fileID: 0}
    TintColor: {r: 0.878, g: 0.502, b: 0.188, a: 1}
  # Kind 3: PublicHumiliation — severe social damage, red
  - Kind: 3
    Icon: {fileID: 0}
    TintColor: {r: 0.816, g: 0.251, b: 0.125, a: 1}
  # Kind 4: AffairRevealed — scandal / romantic, pink
  - Kind: 4
    Icon: {fileID: 0}
    TintColor: {r: 0.816, g: 0.439, b: 0.627, a: 1}
  # Kind 5: Promotion — positive career event, green
  - Kind: 5
    Icon: {fileID: 0}
    TintColor: {r: 0.235, g: 0.702, b: 0.443, a: 1}
  # Kind 6: Firing — negative career event, red
  - Kind: 6
    Icon: {fileID: 0}
    TintColor: {r: 0.816, g: 0.251, b: 0.125, a: 1}
  # Kind 7: KindnessInCrisis — positive prosocial act, green
  - Kind: 7
    Icon: {fileID: 0}
    TintColor: {r: 0.235, g: 0.702, b: 0.443, a: 1}
  # Kind 8: Betrayal — breach of trust, gold / amber warning
  - Kind: 8
    Icon: {fileID: 0}
    TintColor: {r: 0.753, g: 0.627, b: 0.125, a: 1}
  # Kind 9: DeathOrLeaving — loss / departure, muted grey
  - Kind: 9
    Icon: {fileID: 0}
    TintColor: {r: 0.667, g: 0.667, b: 0.667, a: 1}
  # Kind 10: Other — uncategorised catch-all, cool blue-grey
  - Kind: 10
    Icon: {fileID: 0}
    TintColor: {r: 0.533, g: 0.533, b: 0.667, a: 1}
