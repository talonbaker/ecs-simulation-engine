{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ecs-sim-engine.local/schemas/world-state.schema.json",
  "title": "WorldStateDto",
  "description": "Versioned, AI-consumable projection of SimulationSnapshot. Produced by Warden.Telemetry, consumed by Tier-3 Haikus.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "capturedAt", "tick", "clock", "entities", "worldItems", "worldObjects", "invariants"],
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["0.1.0", "0.2.1", "0.3.0", "0.4.0", "0.5.0", "0.5.1"] },
    "capturedAt":    { "type": "string", "format": "date-time" },
    "tick":          { "type": "integer", "minimum": 0 },
    "seed":          { "type": "integer", "minimum": 0, "description": "The RNG seed the sim was booted with. Required for determinism." },
    "simVersion":    { "type": "string", "description": "SimVersion.Full at capture time." },

    "clock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gameTimeDisplay", "dayNumber", "isDaytime", "circadianFactor", "timeScale"],
      "properties": {
        "gameTimeDisplay":  { "type": "string", "maxLength": 32 },
        "dayNumber":        { "type": "integer", "minimum": 0 },
        "isDaytime":        { "type": "boolean" },
        "circadianFactor":  { "type": "number", "minimum": 0, "maximum": 1 },
        "timeScale":        { "type": "number", "minimum": 0, "maximum": 10000 },
        "sun":              { "$ref": "#/$defs/sunState" }
      }
    },

    "entities": {
      "type": "array",
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/entityState" }
    },

    "worldItems": {
      "type": "array",
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/worldItem" }
    },

    "worldObjects": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "#/$defs/worldObject" }
    },

    "transitItems": {
      "type": "array",
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/transitItem" }
    },

    "relationships": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/$defs/relationship" }
    },

    "memoryEvents": {
      "type": "array",
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/memoryEvent" }
    },

    "rooms": {
      "type": "array",
      "maxItems": 64,
      "items": { "$ref": "#/$defs/room" }
    },

    "lightSources": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "#/$defs/lightSource" }
    },

    "lightApertures": {
      "type": "array",
      "maxItems": 64,
      "items": { "$ref": "#/$defs/lightAperture" }
    },

    "chronicle": {
      "type": "array",
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/chronicleEntry" }
    },

    "invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": ["violationCount"],
      "properties": {
        "violationCount": { "type": "integer", "minimum": 0 },
        "recentViolations": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tick", "kind", "message"],
            "properties": {
              "tick":    { "type": "integer", "minimum": 0 },
              "kind":    { "type": "string", "maxLength": 64 },
              "message": { "type": "string", "maxLength": 512 }
            }
          }
        }
      }
    }
  },

  "$defs": {
    "entityState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "shortId", "name", "species", "position", "drives", "physiology"],
      "properties": {
        "id":      { "type": "string", "format": "uuid" },
        "shortId": { "type": "string", "minLength": 1, "maxLength": 16 },
        "name":    { "type": "string", "maxLength": 64 },
        "species": { "type": "string", "enum": ["human", "cat", "unknown"] },

        "position": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "z", "hasPosition"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" },
            "hasPosition": { "type": "boolean" },
            "isMoving":    { "type": "boolean" },
            "moveTarget":  { "type": "string", "maxLength": 32 }
          }
        },

        "drives": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dominant", "eatUrgency", "drinkUrgency", "sleepUrgency", "defecateUrgency", "peeUrgency"],
          "properties": {
            "dominant":        { "type": "string", "enum": ["None", "Eat", "Drink", "Sleep", "Defecate", "Pee"] },
            "eatUrgency":      { "type": "number", "minimum": 0, "maximum": 1 },
            "drinkUrgency":    { "type": "number", "minimum": 0, "maximum": 1 },
            "sleepUrgency":    { "type": "number", "minimum": 0, "maximum": 1 },
            "defecateUrgency": { "type": "number", "minimum": 0, "maximum": 1 },
            "peeUrgency":      { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },

        "physiology": {
          "type": "object",
          "additionalProperties": false,
          "required": ["satiation", "hydration", "bodyTemp", "energy", "sleepiness", "isSleeping"],
          "properties": {
            "satiation":   { "type": "number", "minimum": 0, "maximum": 100 },
            "hydration":   { "type": "number", "minimum": 0, "maximum": 100 },
            "bodyTemp":    { "type": "number", "minimum": 20, "maximum": 45 },
            "energy":      { "type": "number", "minimum": 0, "maximum": 100 },
            "sleepiness":  { "type": "number", "minimum": 0, "maximum": 100 },
            "isSleeping":  { "type": "boolean" },
            "siFill":      { "type": "number", "minimum": 0, "maximum": 1 },
            "liFill":      { "type": "number", "minimum": 0, "maximum": 1 },
            "colonFill":   { "type": "number", "minimum": 0, "maximum": 1 },
            "bladderFill": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },

        "social":         { "$ref": "#/$defs/socialState" },
        "buildFootprint": { "$ref": "#/$defs/buildFootprint" },
        "personalSpace": { "$ref": "#/$defs/personalSpace" }
      }
    },

    "personalSpace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["radiusMeters", "repulsionStrength"],
      "properties": {
        "radiusMeters":      { "type": "number", "minimum": 0, "maximum": 5 },
        "repulsionStrength": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },

    "socialState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "drives":    { "$ref": "#/$defs/drives" },
        "willpower": { "$ref": "#/$defs/willpower" },
        "inhibitions": {
          "type": "array",
          "maxItems": 8,
          "items": { "$ref": "#/$defs/inhibition" }
        },
        "personalityTraits": {
          "type": "array",
          "maxItems": 5,
          "items": { "$ref": "#/$defs/personalityTrait" }
        },
        "currentMood":        { "type": "string", "maxLength": 32 },
        "vocabularyRegister": {
          "type": "string",
          "enum": ["formal", "casual", "crass", "clipped", "academic", "folksy"]
        }
      }
    },

    "drives": {
      "type": "object",
      "additionalProperties": false,
      "required": ["belonging", "status", "affection", "irritation", "attraction", "trust", "suspicion", "loneliness"],
      "properties": {
        "belonging":  { "$ref": "#/$defs/driveValue" },
        "status":     { "$ref": "#/$defs/driveValue" },
        "affection":  { "$ref": "#/$defs/driveValue" },
        "irritation": { "$ref": "#/$defs/driveValue" },
        "attraction": { "$ref": "#/$defs/driveValue" },
        "trust":      { "$ref": "#/$defs/driveValue" },
        "suspicion":  { "$ref": "#/$defs/driveValue" },
        "loneliness": { "$ref": "#/$defs/driveValue" }
      }
    },

    "driveValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "baseline"],
      "properties": {
        "current":  { "type": "integer", "minimum": 0, "maximum": 100 },
        "baseline": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },

    "willpower": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "baseline"],
      "properties": {
        "current":  { "type": "integer", "minimum": 0, "maximum": 100 },
        "baseline": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },

    "inhibition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "strength", "awareness"],
      "properties": {
        "class": {
          "type": "string",
          "enum": ["infidelity", "confrontation", "bodyImageEating", "publicEmotion", "physicalIntimacy", "interpersonalConflict", "riskTaking", "vulnerability"]
        },
        "strength":  { "type": "integer", "minimum": 0, "maximum": 100 },
        "awareness": { "type": "string", "enum": ["known", "hidden"] }
      }
    },

    "personalityTrait": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "value"],
      "properties": {
        "dimension": {
          "type": "string",
          "enum": ["openness", "conscientiousness", "extraversion", "agreeableness", "neuroticism"]
        },
        "value": { "type": "integer", "minimum": -2, "maximum": 2 }
      }
    },

    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "participantA", "participantB", "patterns", "intensity", "historyEventIds"],
      "properties": {
        "id":           { "type": "string", "format": "uuid" },
        "participantA": { "type": "string", "format": "uuid" },
        "participantB": { "type": "string", "format": "uuid" },
        "patterns": {
          "type": "array",
          "maxItems": 2,
          "items": {
            "type": "string",
            "enum": [
              "rival", "oldFlame", "activeAffair", "secretCrush",
              "mentor", "mentee", "bossOf", "reportTo", "friend",
              "alliesOfConvenience", "sleptWithSpouse", "confidant",
              "theThingNobodyTalksAbout"
            ]
          }
        },
        "intensity":       { "type": "integer", "minimum": 0, "maximum": 100 },
        "historyEventIds": {
          "type": "array",
          "maxItems": 1000,
          "items": { "type": "string", "format": "uuid" }
        }
      }
    },

    "memoryEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "tick", "participants", "kind", "scope", "description", "persistent"],
      "properties": {
        "id":   { "type": "string", "format": "uuid" },
        "tick": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "participants": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": { "type": "string", "format": "uuid" }
        },
        "kind":           { "type": "string", "maxLength": 64 },
        "scope":          { "type": "string", "enum": ["pair", "global"] },
        "description":    { "type": "string", "maxLength": 280 },
        "persistent":     { "type": "boolean" },
        "relationshipId": { "type": "string", "format": "uuid" }
      }
    },

    "worldItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id":       { "type": "string", "format": "uuid" },
        "label":    { "type": "string", "maxLength": 32 },
        "rotLevel": { "type": "number", "minimum": 0, "maximum": 100 },
        "isRotten": { "type": "boolean" }
      }
    },

    "worldObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind", "x", "y", "z"],
      "properties": {
        "id":         { "type": "string", "format": "uuid" },
        "name":       { "type": "string", "maxLength": 32 },
        "kind":       { "type": "string", "enum": ["fridge", "sink", "toilet", "bed", "other"] },
        "x":          { "type": "number" },
        "y":          { "type": "number" },
        "z":          { "type": "number" },
        "stockCount": { "type": "integer", "minimum": -1 }
      }
    },

    "transitItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "targetEntityId", "contentLabel", "progress"],
      "properties": {
        "id":             { "type": "string", "format": "uuid" },
        "targetEntityId": { "type": "string", "format": "uuid" },
        "contentLabel":   { "type": "string", "maxLength": 32 },
        "progress":       { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },

    "sunState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["azimuthDeg", "elevationDeg", "dayPhase"],
      "properties": {
        "azimuthDeg":   { "type": "number", "minimum": 0, "maximum": 360 },
        "elevationDeg": { "type": "number", "minimum": -90, "maximum": 90 },
        "dayPhase": {
          "type": "string",
          "enum": ["night", "earlyMorning", "midMorning", "afternoon", "evening", "dusk"]
        }
      }
    },

    "room": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "category", "floor", "boundsRect", "illumination"],
      "properties": {
        "id":   { "type": "string", "format": "uuid" },
        "name": { "type": "string", "maxLength": 64 },
        "category": {
          "type": "string",
          "enum": [
            "breakroom", "bathroom", "cubicleGrid", "office", "conferenceRoom",
            "supplyCloset", "itCloset", "hallway", "stairwell", "elevator",
            "parkingLot", "smokingArea", "loadingDock", "productionFloor", "lobby", "outdoor"
          ]
        },
        "floor": {
          "type": "string",
          "enum": ["basement", "first", "top", "exterior"]
        },
        "boundsRect":   { "$ref": "#/$defs/boundsRect" },
        "illumination": { "$ref": "#/$defs/illumination" }
      }
    },

    "boundsRect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x":      { "type": "integer", "minimum": 0,   "maximum": 512 },
        "y":      { "type": "integer", "minimum": 0,   "maximum": 512 },
        "width":  { "type": "integer", "minimum": 1,   "maximum": 512 },
        "height": { "type": "integer", "minimum": 1,   "maximum": 512 }
      }
    },

    "illumination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ambientLevel", "colorTemperatureK"],
      "properties": {
        "ambientLevel":      { "type": "integer", "minimum": 0,    "maximum": 100 },
        "colorTemperatureK": { "type": "integer", "minimum": 1000, "maximum": 10000 },
        "dominantSourceId":  { "type": "string",  "format": "uuid" }
      }
    },

    "lightSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "state", "intensity", "colorTemperatureK", "position", "roomId"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "kind": {
          "type": "string",
          "enum": [
            "overheadFluorescent", "deskLamp", "serverLed", "breakroomStrip",
            "conferenceTrack", "exteriorWall", "signageGlow", "neon",
            "monitorGlow", "otherInterior"
          ]
        },
        "state": {
          "type": "string",
          "enum": ["on", "off", "flickering", "dying"]
        },
        "intensity":         { "type": "integer", "minimum": 0,    "maximum": 100 },
        "colorTemperatureK": { "type": "integer", "minimum": 1000, "maximum": 10000 },
        "position":          { "$ref": "#/$defs/tilePoint" },
        "roomId":            { "type": "string",  "format": "uuid" }
      }
    },

    "lightAperture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "position", "roomId", "facing", "areaSqTiles"],
      "properties": {
        "id":       { "type": "string", "format": "uuid" },
        "position": { "$ref": "#/$defs/tilePoint" },
        "roomId":   { "type": "string", "format": "uuid" },
        "facing": {
          "type": "string",
          "enum": ["north", "east", "south", "west", "ceiling"]
        },
        "areaSqTiles": { "type": "number", "minimum": 0.5, "maximum": 64 }
      }
    },

    "tilePoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "integer", "minimum": 0, "maximum": 512 },
        "y": { "type": "integer", "minimum": 0, "maximum": 512 }
      }
    },

    "buildFootprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["widthTiles", "depthTiles", "bottomHeight", "topHeight", "canStackOnTop"],
      "properties": {
        "widthTiles":        { "type": "integer", "minimum": 1 },
        "depthTiles":        { "type": "integer", "minimum": 1 },
        "bottomHeight":      { "type": "number",  "minimum": 0 },
        "topHeight":         { "type": "number",  "minimum": 0 },
        "canStackOnTop":     { "type": "boolean" },
        "footprintCategory": { "type": "string",  "maxLength": 64 }
      }
    },

    "chronicleEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "tick", "participants", "description", "persistent"],
      "properties": {
        "id":           { "type": "string", "format": "uuid" },
        "kind":         { "type": "string",
                          "enum": ["spilledSomething", "brokenItem",
                                   "publicArgument", "publicHumiliation",
                                   "affairRevealed", "promotion",
                                   "firing", "kindnessInCrisis",
                                   "betrayal", "deathOrLeaving",
                                   "other"] },
        "tick":         { "type": "integer", "minimum": 0 },
        "participants": { "type": "array", "maxItems": 8,
                          "items": { "type": "string" } },
        "location":     { "type": "string", "maxLength": 64 },
        "description":  { "type": "string", "maxLength": 280 },
        "persistent":   { "type": "boolean" },
        "physicalManifestEntityId": { "type": "string" }
      }
    }
  }
}
