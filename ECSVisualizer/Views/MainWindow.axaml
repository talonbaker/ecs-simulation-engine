<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ECSVisualizer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="900"
        x:Class="ECSVisualizer.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="ECS Biological Simulation"
        Background="#0D0D0D"
        Width="460" MinWidth="380">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="16">

            <!-- ── HEADER: Version + Game Clock + Day/Night + Time Scale ─────── -->
            <Border Background="#141414" CornerRadius="6" Padding="16,14"
                    BorderBrush="#2A2A2A" BorderThickness="1">
                <Grid ColumnDefinitions="*, Auto">

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding VersionDisplay}"
                                   FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                   Foreground="#333333"/>
                        <!-- Game time: large green clock -->
                        <TextBlock Text="{Binding CurrentTimeDisplay}"
                                   FontSize="32" FontFamily="Consolas" FontWeight="Light"
                                   Foreground="#00FF41"/>
                        <!-- Day number + day/night icon -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding DayNightIcon}"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding DayDisplay}"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#444444" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                Spacing="2" Margin="16,0,0,0">
                        <TextBlock Text="TIME SCALE" FontSize="9" LetterSpacing="1"
                                   Foreground="#444444" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TimeScale, StringFormat={}{0:F0}x}"
                                   FontSize="18" FontWeight="Bold" Foreground="#BB86FC"
                                   HorizontalAlignment="Center"/>
                        <Slider Value="{Binding TimeScale}"
                                Minimum="0" Maximum="480" Width="110"
                                TickFrequency="10" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="game speed" FontSize="8" LetterSpacing="1"
                                   Foreground="#2A2A2A" HorizontalAlignment="Center"/>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- ── LIVING ENTITIES ─────────────────────────────────────────────── -->
            <StackPanel Spacing="6">
                <TextBlock Text="LIVING ENTITIES"
                           FontSize="9" FontWeight="Bold" LetterSpacing="2"
                           Foreground="#444444"/>

                <ItemsControl ItemsSource="{Binding LivingEntities}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:EntityViewModel">
                            <Border Margin="0,0,0,4" Padding="14,12"
                                    Background="#141414" CornerRadius="6"
                                    BorderBrush="#252525" BorderThickness="1">
                                <StackPanel Spacing="10">

                                    <!-- Name + ID -->
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   Foreground="#E0E0E0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding EntityId}"
                                                   FontSize="10" FontFamily="Consolas"
                                                   Foreground="#383838" VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Tag display: yellow when active, dim when clear -->
                                    <Border CornerRadius="3" Padding="8,4"
                                            Background="#1E1A00" IsVisible="{Binding HasActiveTags}">
                                        <TextBlock Text="{Binding ActiveTags}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="#FFD60A" FontFamily="Consolas"/>
                                    </Border>
                                    <Border CornerRadius="3" Padding="8,4"
                                            Background="#141414" IsVisible="{Binding !HasActiveTags}">
                                        <TextBlock Text="— no active conditions —"
                                                   FontSize="10" Foreground="#2A2A2A"
                                                   FontFamily="Consolas"/>
                                    </Border>

                                    <!-- Metabolism -->
                                    <StackPanel IsVisible="{Binding HasMetabolism}" Spacing="8">
                                        <Border Background="#0D0D0D" CornerRadius="4" Padding="10,10">
                                            <StackPanel Spacing="10">

                                                <!-- SATIATION resource bar -->
                                                <StackPanel Spacing="4">
                                                    <Grid ColumnDefinitions="70, *, Auto">
                                                        <TextBlock Grid.Column="0" Text="SATIATION"
                                                                   FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                                   Foreground="#666666" VerticalAlignment="Center"/>
                                                        <ProgressBar Grid.Column="1" Margin="6,0"
                                                                     Value="{Binding Satiation}" Maximum="100"
                                                                     Foreground="#30D158" Background="#1A1A1A"
                                                                     Height="7" CornerRadius="4"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding SatiationLabel}"
                                                                   FontSize="11" FontFamily="Consolas"
                                                                   Foreground="#30D158" VerticalAlignment="Center"
                                                                   Width="42" TextAlignment="Right"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding HungerLabel}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#FF6B35" Margin="76,0,0,0"/>
                                                </StackPanel>

                                                <!-- HYDRATION resource bar -->
                                                <StackPanel Spacing="4">
                                                    <Grid ColumnDefinitions="70, *, Auto">
                                                        <TextBlock Grid.Column="0" Text="HYDRATION"
                                                                   FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                                   Foreground="#666666" VerticalAlignment="Center"/>
                                                        <ProgressBar Grid.Column="1" Margin="6,0"
                                                                     Value="{Binding Hydration}" Maximum="100"
                                                                     Foreground="#0A84FF" Background="#1A1A1A"
                                                                     Height="7" CornerRadius="4"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding HydrationLabel}"
                                                                   FontSize="11" FontFamily="Consolas"
                                                                   Foreground="#0A84FF" VerticalAlignment="Center"
                                                                   Width="42" TextAlignment="Right"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding ThirstLabel}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#5AC8FA" Margin="76,0,0,0"/>
                                                </StackPanel>

                                            </StackPanel>
                                        </Border>

                                        <!-- Energy / Sleep -->
                                        <Border IsVisible="{Binding HasEnergy}"
                                                Background="#0D0D14" CornerRadius="4" Padding="10,10"
                                                BorderBrush="#1A1A2A" BorderThickness="1">
                                            <StackPanel Spacing="10">

                                                <!-- ENERGY bar -->
                                                <StackPanel Spacing="4">
                                                    <Grid ColumnDefinitions="70, *, Auto">
                                                        <TextBlock Grid.Column="0" Text="ENERGY"
                                                                   FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                                   Foreground="#666666" VerticalAlignment="Center"/>
                                                        <ProgressBar Grid.Column="1" Margin="6,0"
                                                                     Value="{Binding Energy}" Maximum="100"
                                                                     Foreground="#FFD60A" Background="#1A1A1A"
                                                                     Height="7" CornerRadius="4"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding EnergyLabel}"
                                                                   FontSize="11" FontFamily="Consolas"
                                                                   Foreground="#FFD60A" VerticalAlignment="Center"
                                                                   Width="42" TextAlignment="Right"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding SleepStateLabel}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#555555" Margin="76,0,0,0"/>
                                                </StackPanel>

                                                <!-- SLEEPINESS bar -->
                                                <StackPanel Spacing="4">
                                                    <Grid ColumnDefinitions="70, *, Auto">
                                                        <TextBlock Grid.Column="0" Text="SLEEPINESS"
                                                                   FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                                   Foreground="#666666" VerticalAlignment="Center"/>
                                                        <ProgressBar Grid.Column="1" Margin="6,0"
                                                                     Value="{Binding Sleepiness}" Maximum="100"
                                                                     Foreground="#6E40C9" Background="#1A1A1A"
                                                                     Height="7" CornerRadius="4"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding SleepinessLabel}"
                                                                   FontSize="11" FontFamily="Consolas"
                                                                   Foreground="#6E40C9" VerticalAlignment="Center"
                                                                   Width="42" TextAlignment="Right"/>
                                                    </Grid>
                                                </StackPanel>

                                            </StackPanel>
                                        </Border>

                                        <!-- Brain / Priority Queue -->
                                        <Border IsVisible="{Binding HasDrives}"
                                                Background="#0A0D12" CornerRadius="4" Padding="10,10"
                                                BorderBrush="#1A2030" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <Grid ColumnDefinitions="70, *">
                                                    <TextBlock Grid.Column="0" Text="BRAIN"
                                                               FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                               Foreground="#666666" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding DominantDesire}"
                                                               FontSize="13" FontWeight="Bold"
                                                               Foreground="#64D2FF" FontFamily="Consolas"/>
                                                </Grid>
                                                <TextBlock Text="{Binding DriveScores}"
                                                           FontSize="10" FontFamily="Consolas"
                                                           Foreground="#2A3A4A" Margin="76,0,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Mood / Plutchik Emotions -->
                                        <Border IsVisible="{Binding HasMood}"
                                                Background="#0D0A14" CornerRadius="4" Padding="10,10"
                                                BorderBrush="#2A1A30" BorderThickness="1">
                                            <StackPanel Spacing="8">

                                                <!-- Section header + valence -->
                                                <Grid ColumnDefinitions="*, Auto">
                                                    <TextBlock Grid.Column="0" Text="EMOTIONS"
                                                               FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                               Foreground="#666666" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding MoodValence, StringFormat='valence {0}'}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#555555"/>
                                                </Grid>

                                                <!-- Active emotion tags -->
                                                <Border CornerRadius="3" Padding="6,3"
                                                        Background="#1A0E2A" IsVisible="{Binding HasActiveEmotions}">
                                                    <TextBlock Text="{Binding ActiveEmotionTags}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#BF5AF2" FontFamily="Consolas"
                                                               TextWrapping="Wrap"/>
                                                </Border>

                                                <!-- Positive emotions (warm tones) -->
                                                <!-- JOY -->
                                                <Grid ColumnDefinitions="80, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="JOY"
                                                               FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                               Foreground="#555555" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Column="1" Margin="4,0"
                                                                 Value="{Binding MoodJoy}" Maximum="100"
                                                                 Foreground="#FFD60A" Background="#1A1A0A"
                                                                 Height="5" CornerRadius="3"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding MoodJoy, StringFormat={}{0:F0}}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#FFD60A" Width="28" TextAlignment="Right"/>
                                                </Grid>

                                                <!-- TRUST -->
                                                <Grid ColumnDefinitions="80, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="TRUST"
                                                               FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                               Foreground="#555555" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Column="1" Margin="4,0"
                                                                 Value="{Binding MoodTrust}" Maximum="100"
                                                                 Foreground="#30D158" Background="#0A1A0A"
                                                                 Height="5" CornerRadius="3"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding MoodTrust, StringFormat={}{0:F0}}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#30D158" Width="28" TextAlignment="Right"/>
                                                </Grid>

                                                <!-- ANTICIPATION -->
                                                <Grid ColumnDefinitions="80, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="ANTICIPATION"
                                                               FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                               Foreground="#555555" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Column="1" Margin="4,0"
                                                                 Value="{Binding MoodAnticipation}" Maximum="100"
                                                                 Foreground="#FF9F0A" Background="#1A0D00"
                                                                 Height="5" CornerRadius="3"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding MoodAnticipation, StringFormat={}{0:F0}}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#FF9F0A" Width="28" TextAlignment="Right"/>
                                                </Grid>

                                                <!-- Divider -->
                                                <Border Height="1" Background="#2A2A2A" Margin="0,2"/>

                                                <!-- Negative emotions (cool/intense tones) -->
                                                <!-- ANGER -->
                                                <Grid ColumnDefinitions="80, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="ANGER"
                                                               FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                               Foreground="#555555" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Column="1" Margin="4,0"
                                                                 Value="{Binding MoodAnger}" Maximum="100"
                                                                 Foreground="#FF453A" Background="#1A0A0A"
                                                                 Height="5" CornerRadius="3"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding MoodAnger, StringFormat={}{0:F0}}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#FF453A" Width="28" TextAlignment="Right"/>
                                                </Grid>

                                                <!-- SADNESS -->
                                                <Grid ColumnDefinitions="80, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="SADNESS"
                                                               FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                               Foreground="#555555" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Column="1" Margin="4,0"
                                                                 Value="{Binding MoodSadness}" Maximum="100"
                                                                 Foreground="#0A84FF" Background="#0A0A1A"
                                                                 Height="5" CornerRadius="3"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding MoodSadness, StringFormat={}{0:F0}}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#0A84FF" Width="28" TextAlignment="Right"/>
                                                </Grid>

                                                <!-- DISGUST / BOREDOM -->
                                                <Grid ColumnDefinitions="80, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="DISGUST"
                                                               FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                               Foreground="#555555" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Column="1" Margin="4,0"
                                                                 Value="{Binding MoodDisgust}" Maximum="100"
                                                                 Foreground="#6E40C9" Background="#0E0A1A"
                                                                 Height="5" CornerRadius="3"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding MoodDisgust, StringFormat={}{0:F0}}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#6E40C9" Width="28" TextAlignment="Right"/>
                                                </Grid>

                                                <!-- FEAR -->
                                                <Grid ColumnDefinitions="80, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="FEAR"
                                                               FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                               Foreground="#555555" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Column="1" Margin="4,0"
                                                                 Value="{Binding MoodFear}" Maximum="100"
                                                                 Foreground="#5AC8FA" Background="#0A0E1A"
                                                                 Height="5" CornerRadius="3"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding MoodFear, StringFormat={}{0:F0}}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#5AC8FA" Width="28" TextAlignment="Right"/>
                                                </Grid>

                                                <!-- SURPRISE -->
                                                <Grid ColumnDefinitions="80, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="SURPRISE"
                                                               FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                               Foreground="#555555" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Column="1" Margin="4,0"
                                                                 Value="{Binding MoodSurprise}" Maximum="100"
                                                                 Foreground="#FF6B35" Background="#1A0D0A"
                                                                 Height="5" CornerRadius="3"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding MoodSurprise, StringFormat={}{0:F0}}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#FF6B35" Width="28" TextAlignment="Right"/>
                                                </Grid>

                                            </StackPanel>
                                        </Border>

                                        <!-- Stomach -->
                                        <Border IsVisible="{Binding HasStomach}"
                                                Background="#0D0D0D" CornerRadius="4" Padding="10,10">
                                            <StackPanel Spacing="4">
                                                <Grid ColumnDefinitions="70, *, Auto">
                                                    <TextBlock Grid.Column="0" Text="STOMACH"
                                                               FontSize="9" FontWeight="Bold" LetterSpacing="1"
                                                               Foreground="#666666" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Column="1" Margin="6,0"
                                                                 Value="{Binding StomachFill}" Maximum="100"
                                                                 Foreground="#FF9F0A" Background="#1A1A1A"
                                                                 Height="7" CornerRadius="4"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding StomachLabel}"
                                                               FontSize="10" FontFamily="Consolas"
                                                               Foreground="#FF9F0A" VerticalAlignment="Center"
                                                               Width="42" TextAlignment="Right"/>
                                                </Grid>
                                                <TextBlock Text="{Binding DigestionLabel}"
                                                           FontSize="10" FontFamily="Consolas"
                                                           Foreground="#333333" Margin="76,0,0,0"/>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ── PIPELINE: Esophagus Transit ────────────────────────────── -->
            <StackPanel Spacing="6">
                <TextBlock Text="ESOPHAGUS PIPELINE"
                           FontSize="9" FontWeight="Bold" LetterSpacing="2"
                           Foreground="#444444"/>

                <TextBlock Text="— nothing in transit —"
                           IsVisible="{Binding !PipelineEntities.Count}"
                           FontSize="11" FontFamily="Consolas"
                           Foreground="#2A2A2A" Margin="4,0"/>

                <ItemsControl ItemsSource="{Binding PipelineEntities}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:EntityViewModel">
                            <Border Margin="0,0,0,4" Padding="12,10"
                                    Background="#12101A" CornerRadius="6"
                                    BorderBrush="#2A2040" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding TransitLabel}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   Foreground="#BF5AF2"/>
                                        <TextBlock Grid.Column="1" Text="{Binding EntityId}"
                                                   FontSize="10" FontFamily="Consolas"
                                                   Foreground="#333333"/>
                                    </Grid>
                                    <ProgressBar Value="{Binding TransitProgress}" Maximum="100"
                                                 Foreground="#BF5AF2" Background="#1E1A2A"
                                                 Height="5" CornerRadius="3"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</Window>
