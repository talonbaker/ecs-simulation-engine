<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ECSVisualizer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="ECSVisualizer.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ECS Biological Simulation"
        Background="#121212">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *">
        <StackPanel Grid.Row="0" Margin="20" Spacing="15">
            <TextBlock Text="WORLD SIMULATION CLOCK" 
                       FontSize="12" 
                       FontWeight="Bold" 
                       LetterSpacing="2"
                       Foreground="#888888"/>
            
            <Grid ColumnDefinitions="*, Auto">
                <Border Grid.Column="0" Padding="20,10" Background="#1E1E1E" CornerRadius="4" BorderBrush="#333333" BorderThickness="1">
                    <TextBlock Text="{Binding CurrentTimeDisplay}" 
                               FontSize="48" 
                               FontFamily="Consolas"
                               FontWeight="Light"
                               Foreground="#00FF41"/> </Border>
                
                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="TIME SCALE" FontSize="10" Foreground="#666666" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TimeScale, StringFormat={}{0:F1}x}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#BB86FC" 
                               HorizontalAlignment="Center"/>
                    <Slider Value="{Binding TimeScale}" 
                            Minimum="0" Maximum="10" 
                            Width="120"
                            TickFrequency="0.1" 
                            IsSnapToTickEnabled="True"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20,0,20,20" RowDefinitions="Auto, *">
            <Border Grid.Row="0" Padding="0,5" BorderBrush="#333333" BorderThickness="0,0,0,1" Margin="0,0,0,10">
                <TextBlock Text="LIVE ENTITY FEED" FontSize="12" FontWeight="Bold" LetterSpacing="1" Foreground="#888888"/>
            </Border>

            <ListBox Grid.Row="1" 
                     ItemsSource="{Binding ActiveEntityList}" 
                     Background="Transparent"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,2" 
                                Padding="12,8" 
                                Background="#1A1A1A" 
                                CornerRadius="2" 
                                BorderBrush="#252525" 
                                BorderThickness="1">
                            <TextBlock Text="{Binding}" 
                                       Foreground="#DCDCDC" 
                                       FontFamily="Consolas" 
                                       FontSize="13"
                                       TextWrapping="Wrap">
                                <TextBlock.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                                    </Transitions>
                                </TextBlock.Transitions>
                            </TextBlock>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>